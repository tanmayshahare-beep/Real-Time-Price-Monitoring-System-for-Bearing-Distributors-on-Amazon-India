MONGO_URI=mongodb://localhost:27017
MONGO_DB=amazon_pricing
PROXY_LIST=http://user:pass@proxy1.com:8000,http://user:pass@proxy2.com:8000
PROXY_ROTATION_ENABLED=true
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=hf.co/quelmap/Lightning-4b-GGUF-short-ctx:Q4_K_M

# Target queries
TARGET_QUERIES=SKF bearing 6205
DECOY_QUERIES=bearing 6204, SKF 6305 bearing, NSK bearing 6206, FAG bearing 6205
MONITORED_ASINS=

# Scheduling with jitter
SCRAPE_INTERVAL_HOURS=6
SCHEDULE_JITTER_MINUTES=30
ASIN_CHECK_DELAY_MIN=30
ASIN_CHECK_DELAY_MAX=120

# Behavioral timing (human-like)
REQUEST_DELAY_MIN=2
REQUEST_DELAY_MAX=8
READING_TIME_SEARCH_MIN=3
READING_TIME_SEARCH_MAX=10
READING_TIME_PRODUCT_MIN=8
READING_TIME_PRODUCT_MAX=25
READING_TIME_OFFERS_MIN=15
READING_TIME_OFFERS_MAX=45
BETWEEN_SEARCHES_MIN=15
BETWEEN_SEARCHES_MAX=90
SESSION_START_DELAY_MIN=5
SESSION_START_DELAY_MAX=15
HESITATION_PROBABILITY=0.3

# Logging
LOG_LEVEL=INFO
LOG_FILE=amazon_scraper.log
ACTIVITY_LOG_FILE=activity.log
STATS_FILE=bot_stats.json
